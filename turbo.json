{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".nvmrc", ".yarnrc.yml", "tsconfig.json"],
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "prepare": {
      "inputs": [
        "package.json",
        "src/**",
        "nitrogen/**",
        "nitro.json",
        "tsconfig.json",
        "tsconfig.build.json"
      ],
      "outputs": ["lib/**", "nitrogen/generated/**"]
    },
    "typecheck": {
      "dependsOn": ["^prepare"],
      "inputs": ["src/**", "tsconfig.json", "package.json"],
      "outputs": []
    },
    "lint": {
      "inputs": ["src/**", "*.{js,ts,tsx}", "package.json"],
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "build:android": {
      "dependsOn": ["^prepare"],
      "env": ["ANDROID_HOME", "ORG_GRADLE_PROJECT_newArchEnabled"],
      "inputs": [
        "package.json",
        "android/**",
        "!android/.gradle/**",
        "!android/build/**",
        "!android/app/build/**"
      ],
      "outputs": []
    },
    "build:ios": {
      "dependsOn": ["^prepare"],
      "env": [
        "RCT_NEW_ARCH_ENABLED",
        "RCT_REMOVE_LEGACY_ARCH",
        "RCT_USE_RN_DEP",
        "RCT_USE_PREBUILT_RNCORE"
      ],
      "inputs": ["package.json", "ios/**", "!ios/build/**", "!ios/Pods/**"],
      "outputs": []
    }
  }
}
